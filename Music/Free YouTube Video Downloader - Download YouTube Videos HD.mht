.dialog { position: relative; z-index: 2; display: flex; -webkit-box-orient: vertical; -webkit-box-direction: normal; flex-direction: column; max-height: 100%; max-width: 100%; box-sizing: border-box; padding: 16px; margin: 0px auto; overflow: hidden auto; font-size: 1.3rem; color: rgb(3, 3, 3); background-color: rgb(255, 255, 255); border-width: medium; border-style: none; border-color: currentcolor; border-image: initial; }

.dialog.modern-dialog { box-shadow: rgba(0, 0, 0, 0.25) 0px 0px 24px 12px; }

.dialog.rounded-container { border-radius: 12px; }

.dialog.modern-dialog-layout { padding: 0px; border-radius: 24px; }

.dialog-body { overflow: hidden auto; max-height: 100vh; }

.dialog.scrollable .dialog-body { overflow: visible; max-height: unset; }

.dialog-container { position: fixed; inset: 0px; display: flex; -webkit-box-align: center; align-items: center; -webkit-box-pack: center; justify-content: center; z-index: 4; }

.dialog-header { display: flex; -webkit-box-orient: vertical; -webkit-box-direction: normal; flex-direction: column; }

.dialog-buttons, .dialog-header { flex-shrink: 0; }

.dialog-buttons { display: flex; -webkit-box-align: center; align-items: center; -webkit-box-pack: end; justify-content: flex-end; margin-top: 12px; }

.dialog-buttons > * { margin-left: 8px; }

.dialog-buttons > :first-child { margin-left: 0px; }

.dialog-flex-button { -webkit-box-flex: 1; flex: 1 1 0%; }

.dialog-flex-button .button-with-icon.compact { margin: 0px; }

.dialog-body a, .dialog-header a { color: rgb(6, 95, 212); }

.dialog-body ytm-menu-item a { color: currentcolor; }

@media (min-width: 330px) and (min-height: 330px) {
  .dialog { min-width: 250px; max-width: 356px; }
  .dialog-container { margin: 0px 40px; padding: 0 env(safe-area-inset-right) env(safe-area-inset-bottom) env(safe-area-inset-left); }
}

.dialog-fullscreen { min-width: 100%; min-height: 100%; margin: 0px; padding: 0px; height: 1px; }

.dialog-fullscreen > .dialog-body { height: 100%; }

.dialog.modern-dialog-layout.dialog-fullscreen { border-radius: 0px; }

.dialog-container.dialog-fullscreen { margin: 0px; }

c3-toast { display: block; position: fixed; z-index: 5; left: 0px; right: 0px; bottom: 0px; box-sizing: border-box; padding: 14px 24px; font-size: 1.4rem; color: rgb(255, 255, 255); background: rgb(15, 15, 15); will-change: transform; margin-bottom: -100%; }

c3-toast.hug-toast { max-width: 344px; }

c3-toast.inverse-theme { background: rgb(255, 255, 255); color: rgb(3, 3, 3); }

c3-toast.inverse-theme .button-with-icon { color: rgb(6, 95, 212); }

[has-safe-area-in-max="true"] c3-toast { padding: 14px max(24px,env(safe-area-inset-right)) 14px max(24px,env(safe-area-inset-left)); }

[has-pivot-bar="true"] c3-toast { --safe-area-inset-top: env(safe-area-inset-top); --safe-area-inset-bottom: env(safe-area-inset-bottom); bottom: calc(48px + var(--safe-area-inset-bottom)); margin-bottom: calc(-100% + var(--safe-area-inset-bottom)); z-index: 2; }

[modal-open-body] c3-toast, [shorts-player="true"] c3-toast { bottom: 8px; margin-bottom: -100%; z-index: 5; }

